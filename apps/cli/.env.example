# Letta Cloud API (for Data Foundry)
# Get your API key at https://app.letta.com/api-keys
LETTA_API_KEY=your_letta_api_key_here

# Data Foundry Agent ID (pre-configured agent on Letta Cloud)
DATA_FOUNDRY_AGENT_ID=agent-xxxxx

# HuggingFace Hub (optional, for dataset search)
HF_TOKEN=your_huggingface_token_here
